PORT=8000
FRONTEND_PORT=5173

DATABASE_URL=postgresql://postgres:your_db_password@db:5432/language_db

APP_BASE_URL=https://your-domain.com
FRONTEND_BASE_URL=https://your-domain.com/language-app-web/
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

SESSION_COOKIE_NAME=language_app_session
SESSION_TTL_DAYS=30
STARLETTE_SESSION_SECRET=change_this_to_a_long_random_secret
SESSION_SAME_SITE=lax
SESSION_HTTPS_ONLY=true

CORS_ALLOW_ORIGINS=https://your-domain.com,https://www.your-domain.com

OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret